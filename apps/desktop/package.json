{
  "name": "@cmdrzone/desktop",
  "version": "0.2.0",
  "private": true,
  "description": "CmdrZone — Project Command Center (desktop app)",
  "license": "GPL-3.0-or-later",
  "author": "Fredrik Hammarström <fredrik@innoveramera.se>",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node ../../scripts/patch-electron-name.mjs && electron-vite dev",
    "build": "electron-vite build && node ../../scripts/build-tools.mjs",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web",
    "dist": "electron-vite build && electron-builder",
    "release": "electron-vite build && electron-builder --publish always"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "electron-updater": "^6.8.9",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "@xterm/addon-clipboard": "^0.1.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-serialize": "^0.13.0",
    "@xterm/addon-unicode11": "^0.8.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "monaco-editor": "^0.52.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.3",
    "vite": "^6.4.3",
    "zod": "^3.24.1",
    "zustand": "^5.0.3"
  }
}
