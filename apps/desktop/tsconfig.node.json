{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "lib": ["ES2023"],
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["src/shared/*"],
      "@core/*": ["src/core/*"],
      "@pty/*": ["src/pty/*"]
    },
    "noEmit": true
  },
  "include": [
    "src/main",
    "src/preload",
    "src/core",
    "src/pty",
    "src/shared",
    "electron.vite.config.ts"
  ]
}
