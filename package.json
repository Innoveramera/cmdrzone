{
  "name": "cmdrzone-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Desktop command center for many projects + AI coding agents",
  "license": "GPL-3.0-or-later",
  "author": "Fredrik Hammarström <fredrik@innoveramera.se>",
  "repository": {
    "type": "git",
    "url": "https://github.com/Innoveramera/cmdrzone.git"
  },
  "homepage": "https://github.com/Innoveramera/cmdrzone#readme",
  "bugs": "https://github.com/Innoveramera/cmdrzone/issues",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @cmdrzone/desktop dev",
    "build": "pnpm --filter @cmdrzone/desktop build",
    "start": "pnpm --filter @cmdrzone/desktop start",
    "dist": "pnpm --filter @cmdrzone/desktop dist",
    "app:install": "pnpm dist && rm -rf /Applications/CmdrZone.app && cp -R apps/desktop/release/mac-arm64/CmdrZone.app /Applications/ && echo 'Installed /Applications/CmdrZone.app'",
    "typecheck": "pnpm -r typecheck",
    "rebuild:native": "node scripts/rebuild-native.mjs"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "better-sqlite3",
      "node-pty"
    ]
  }
}
